diff --git a/cmake/overlays/ports/szip/portfile.cmake b/cmake/overlays/ports/szip/portfile.cmake
new file mode 100644
index 0000000..82c3e9b
--- /dev/null
+++ b/cmake/overlays/ports/szip/portfile.cmake
@@ -0,0 +1,48 @@
+# 1. Suppress warnings regarding missing headers/libraries for this wrapper port
+set(VCPKG_POLICY_EMPTY_INCLUDE_FOLDER enabled)
+set(VCPKG_POLICY_EMPTY_PACKAGE enabled)
+
+# 2. Deploy the CMake target forwarding configuration
+file(WRITE "${CURRENT_PACKAGES_DIR}/share/szip/szipConfig.cmake" [[
+if(TARGET libaec::aec AND NOT TARGET SZIP::SZIP)
+    add_library(SZIP::SZIP INTERFACE IMPORTED)
+    target_link_libraries(SZIP::SZIP INTERFACE libaec::aec libaec::sz)
+    set(SZIP_FOUND TRUE)
+elseif(TARGET aec AND NOT TARGET SZIP::SZIP)
+    add_library(SZIP::SZIP INTERFACE IMPORTED)
+    target_link_libraries(SZIP::SZIP INTERFACE aec sz)
+    set(SZIP_FOUND TRUE)
+else()
+    get_filename_component(_SZIP_ROOT "${CMAKE_CURRENT_LIST_DIR}/../../" ABSOLUTE)
+    add_library(SZIP::SZIP INTERFACE IMPORTED)
+    target_include_directories(SZIP::SZIP INTERFACE "${_SZIP_ROOT}/include")
+    target_link_libraries(SZIP::SZIP INTERFACE 
+        "${_SZIP_ROOT}/lib/libaec.so" 
+        "${_SZIP_ROOT}/lib/libsz.so"
+    )
+    set(SZIP_FOUND TRUE)
+endif()
+]])
+
+# 3. Deploy szip.pc for both release and debug paths to satisfy vcpkg_fixup_pkgconfig
+set(PC_TEMPLATE [[
+prefix=${pcfiledir}/../..
+exec_prefix=${prefix}
+libdir=${prefix}/lib
+includedir=${prefix}/include
+
+Name: szip
+Description: Wrapper PC file redirecting szip to libaec
+Version: 1.0.0
+Cflags: -I${includedir}
+Libs: -L${libdir} -laec -lsz
+]])
+
+file(MAKE_DIRECTORY "${CURRENT_PACKAGES_DIR}/lib/pkgconfig")
+file(WRITE "${CURRENT_PACKAGES_DIR}/lib/pkgconfig/szip.pc" "${PC_TEMPLATE}")
+
+file(MAKE_DIRECTORY "${CURRENT_PACKAGES_DIR}/debug/lib/pkgconfig")
+file(WRITE "${CURRENT_PACKAGES_DIR}/debug/lib/pkgconfig/szip.pc" "${PC_TEMPLATE}")
+
+# 4. Add the mandatory copyright file
+file(WRITE "${CURRENT_PACKAGES_DIR}/share/szip/copyright" "Dummy redirect port for libaec compatibility.")
